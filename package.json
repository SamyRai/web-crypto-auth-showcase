{
  "name": "web-crypto-auth-showcase",
  "version": "1.0.0",
  "description": "A React + TypeScript + Vite app that demonstrates browser security and cryptography.",
  "homepage": "https://SamyRai.github.io/web-crypto-auth-showcase/",
  "author": "web-crypto-auth-showcase contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SamyRai/web-crypto-auth-showcase.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:client": "vite build --outDir dist/static",
    "build:server": "vite build --ssr src/entry-server.tsx --outDir dist/server",
    "prerender": "node --experimental-strip-types scripts/prerender.ts",
    "build": "tsc -b && yarn build:client && yarn build:server && yarn prerender && cp -r dist/static/* dist/",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.16.0",
    "zod": "^4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^7.3.1"
  }
}
